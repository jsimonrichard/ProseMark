{
  "$schema": "./node_modules/turbo/schema.json",
  "tasks": {
    "build": {
      "outputs": ["dist/**"],
      "dependsOn": ["^build"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "$TURBO_ROOT$/eslint.config-base.ts",
        "$TURBO_ROOT$/tsconfig.base.json"
      ]
    },
    "check-types": {
      "dependsOn": ["^build"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "$TURBO_ROOT$/eslint.config-base.ts",
        "$TURBO_ROOT$/tsconfig.base.json"
      ]
    },
    "dev": {
      "persistent": true,
      "cache": false
    },
    "lint": {
      "dependsOn": ["^build"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "$TURBO_ROOT$/eslint.config-base.ts",
        "$TURBO_ROOT$/tsconfig.base.json"
      ]
    },
    "//#format": {},
    "//#format:check": {
      "outputs": []
    },
    "ci:publish": {
      "dependsOn": ["^ci:publish"],
      "cache": false
    }
  }
}
