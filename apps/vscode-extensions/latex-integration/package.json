{
  "name": "vscode-prosemark-latex-integration",
  "displayName": "ProseMark - LaTeX math (MathJax) integration",
  "description": "Renders $...$ and $$...$$ math in the ProseMark editor using MathJax (@prosemark/latex)",
  "publisher": "jsimonrichard",
  "version": "0.0.1",
  "repository": {
    "type": "GitHub",
    "url": "https://github.com/jsimonrichard/ProseMark"
  },
  "author": {
    "name": "J. Simon Richard",
    "url": "https://jsimonrichard.com"
  },
  "license": "MIT",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension/extension.js",
  "extensionDependencies": [
    "jsimonrichard.vscode-prosemark"
  ],
  "scripts": {
    "vscode:prepublish": "bun run build",
    "package": "vsce package",
    "publish": "vsce publish",
    "ci:publish": "bash ../../../scripts/ci-publish-vscode-extension.sh",
    "ci:publish:dry-run": "DRY_RUN=1 bash ../../../scripts/ci-publish-vscode-extension.sh",
    "build": "bun run check-types && bun run lint && tsdown && vite build",
    "dev": "tsc --noEmit && concurrently \"tsc -w\" \"tsdown --watch\"",
    "dev-tests": "tsc -p . -w --outDir out",
    "pretest": "bun run build-tests && bun run build && bun run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "dependencies": {
    "@prosemark/latex": "workspace:*",
    "@prosemark/vscode-extension-integrator": "workspace:*"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^24.10.4",
    "@types/vscode": "^1.90.0",
    "@typescript-eslint/parser": "^8.50.0",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.7.1",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.2",
    "tsdown": "^0.15.6",
    "typescript": "^5.9.3",
    "vite": "^8.0.5"
  }
}
